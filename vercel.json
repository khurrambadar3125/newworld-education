{
  "crons": [
    {
      "path": "/api/cron/daily-question",
      "schedule": "0 1,3,9,13,15 * * *"
    },
    {
      "path": "/api/cron/health-check",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/weekly-plans",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/cron/missed-sessions",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/exam-countdown",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/referral-daily",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/cron/referral-weekly",
      "schedule": "0 4 * * 1"
    },
    {
      "path": "/api/cron/championship-master",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/cron/championship-emails",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/championship-weekly",
      "schedule": "0 4 * * 1"
    },
    {
      "path": "/api/cron/championship-intelligence",
      "schedule": "0 5 * * 1"
    },
    {
      "path": "/api/cron/behaviour-analysis",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/cron/signal-analysis",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/cron/auto-improve",
      "schedule": "0 22 * * 6"
    },
    {
      "path": "/api/cron/evolution-report",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/national-insights",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/backup-kv",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/cron/predictive-analysis",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/phase-transition",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/publish-news",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/self-heal",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/weekly-progress",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/lead-drip",
      "schedule": "0 3 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/favicon.svg",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/og-image.png",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
