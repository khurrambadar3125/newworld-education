{
  "crons": [
    {
      "path": "/api/cron/daily-question",
      "schedule": "0 1,3,9,13,15 * * *"
    },
    {
      "path": "/api/cron/health-check",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/weekly-plans",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/cron/missed-sessions",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/exam-countdown",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/referral-daily",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/cron/referral-weekly",
      "schedule": "0 4 * * 1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
